CREATE TABLE M_SYS_CURRENCY (
    I_SCY_ID        TEXT    PRIMARY KEY NOT NULL,

    I_CODE          TEXT    NOT NULL UNIQUE,  -- THB, USD, BTC …
    I_NAME          TEXT    NOT NULL,
    I_SYMBOL        TEXT    NOT NULL,

    I_CREATED_AT    INTEGER NOT NULL,
    I_UPDATED_AT    INTEGER,
    I_MODIFY_COUNT  INTEGER NOT NULL DEFAULT 0,

    I_CREATED_BY    TEXT    NOT NULL,
    I_UPDATED_BY    TEXT
);

CREATE INDEX IDX_SCY_CODE ON M_SYS_CURRENCY(I_CODE);