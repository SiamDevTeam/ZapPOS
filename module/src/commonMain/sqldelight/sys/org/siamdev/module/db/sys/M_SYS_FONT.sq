CREATE TABLE M_SYS_FONT (
    I_SF_ID         TEXT    PRIMARY KEY NOT NULL,

    I_NAME          TEXT    NOT NULL UNIQUE,
    I_SIZE          REAL    NOT NULL,

    I_CREATED_AT    INTEGER NOT NULL,
    I_UPDATED_AT    INTEGER,
    I_MODIFY_COUNT  INTEGER NOT NULL DEFAULT 0,

    I_CREATED_BY    TEXT    NOT NULL,
    I_UPDATED_BY    TEXT
);