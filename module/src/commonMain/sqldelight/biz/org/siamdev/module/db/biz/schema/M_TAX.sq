CREATE TABLE M_TAX (
    I_TAX_ID            TEXT    PRIMARY KEY NOT NULL,

    I_TAX_DESC          TEXT    NOT NULL,
    I_TAX_RATE          REAL    NOT NULL,
    I_IS_ACTIVE         INTEGER NOT NULL    CHECK (I_IS_ACTIVE IN (0, 1)), -- 0=inactive, 1=active

    I_CREATED_AT        INTEGER,
    I_UPDATED_AT        INTEGER,
    I_MODIFY_COUNT      INTEGER DEFAULT 0,

    I_CREATED_BY        TEXT,
    I_UPDATED_BY        TEXT
);