CREATE TABLE T_STOCK (
    I_PRD_ID            TEXT    PRIMARY KEY NOT NULL,

    I_QTY_ON_HAND       REAL    NOT NULL DEFAULT 0  CHECK (I_QTY_ON_HAND >= 0),

    I_CREATED_AT        INTEGER,
    I_UPDATED_AT        INTEGER,
    I_MODIFY_COUNT      INTEGER DEFAULT 0,

    I_CREATED_BY        TEXT,
    I_UPDATED_BY        TEXT
);